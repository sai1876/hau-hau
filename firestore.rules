rules_version = '2';

// =============================================================================
// Hau-Hau POS — Firestore Security Rules (Production Hardened)
// =============================================================================
// These rules enforce cryptographic claims-based security and restrict
// sensitive database operations to the Server Admin SDK.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions (Claims-Only Enforced)
    // -------------------------------------------------------------------------

    // Returns true if the request comes from an authenticated Firebase user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the authenticated user has the 'owner' custom claim.
    function isOwner() {
      return isAuthenticated() && (request.auth.token.role == 'owner' || request.auth.token.role == 'admin');
    }

    // Returns true if the authenticated user is an active staff member or owner.
    function isActiveStaff() {
      return isOwner() ||
             (isAuthenticated() &&
              request.auth.token.role == 'staff' &&
              request.auth.token.status == 'active');
    }

    // Returns true if the authenticated user is a demo user.
    // Demo accounts are read-only and cannot mutate production Firestore state.
    function isDemoUser() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*demo.*') ||
        request.auth.token.isDemo == true
      );
    }

    // -------------------------------------------------------------------------
    // `menu` collection
    // -------------------------------------------------------------------------
    match /menu/{itemId} {
      // Active staff/owners can read the menu.
      allow read: if isActiveStaff();

      // Only non-demo owners can modify menu items, and price must be positive.
      allow create, update: if isOwner() && !isDemoUser() && request.resource.data.price > 0;
      allow delete: if isOwner() && !isDemoUser();
    }

    // -------------------------------------------------------------------------
    // `orders` collection
    // -------------------------------------------------------------------------
    match /orders/{orderId} {
      // Active staff/owners can read orders.
      allow read: if isActiveStaff();

      // Direct client writes (creates, updates, deletes) are denied.
      // All order creations and state modifications must flow through secure API routes.
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // `staff` collection
    // -------------------------------------------------------------------------
    match /staff/{staffId} {
      // Any active staff member can read profiles. A user can read their own profile.
      allow read: if isActiveStaff() || (isAuthenticated() && request.auth.uid == staffId);

      // Staff creation and deletion are handled via secure API routes using Admin SDK.
      allow create, delete: if false;

      // Staff members can only update their own name/email/phone. Owners can update via API.
      allow update: if isAuthenticated() &&
                    request.auth.uid == staffId &&
                    !isDemoUser() &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['name', 'emailOrPhone']);
    }

    // -------------------------------------------------------------------------
    // `tokens` collection
    // -------------------------------------------------------------------------
    match /tokens/{tokenId} {
      // Active staff/owners can read token accounts.
      allow read: if isActiveStaff();

      // Direct client writes allowed for owner/admin (for updating name/cardNo)
      allow write: if isOwner() && !isDemoUser();
    }

    // -------------------------------------------------------------------------
    // `token_transactions` collection (Immutable Ledger)
    // -------------------------------------------------------------------------
    match /token_transactions/{txId} {
      // Active staff/owners can read transaction logs.
      allow read: if isActiveStaff();

      // Direct client writes are strictly denied.
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // `settings` collection
    // -------------------------------------------------------------------------
    match /settings/{settingsId} {
      allow read: if isActiveStaff();
      allow create, update: if isOwner() && !isDemoUser();
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // `audit_logs` collection (Immutable Operational Logs)
    // -------------------------------------------------------------------------
    match /audit_logs/{logId} {
      allow read: if isOwner();
      
      // Allow client creation for LocalStorage fallback mode only.
      // In Firebase mode, audit logs are set via Admin SDK.
      allow create: if isActiveStaff() && !isDemoUser();
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // All other collections — deny by default
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
