rules_version = '2';

// =============================================================================
// Hau-Hau POS — Firestore Security Rules
// =============================================================================
// These rules are the PRIMARY security layer between clients and Firestore.
// Because all role checks in the app are currently client-side, these rules
// provide the server-enforced safety net.
//
// Current architecture:
//   - Firebase Auth UIDs map to documents in the `staff` collection
//   - The `role` field in that document determines access level
//
// ⚠ IMPORTANT LIMITATION:
//   Role checks below read the caller's staff document to determine their role.
//   This pattern is correct but has a small risk: if the `role` field in Firestore
//   is tampered with, a user could elevate their own permissions.
//   The recommended production fix is to use Firebase Custom Claims via the
//   Firebase Admin SDK (see SECURITY.md for the recommended path).
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    // Returns true if the request comes from an authenticated Firebase user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Fetches the caller's staff profile document.
    function callerProfile() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }

    // Returns true if the authenticated user's email matches the owner email.
    // This is a lightweight check that doesn't require a Firestore document lookup.
    function isOwnerByEmail() {
      return isAuthenticated() &&
             request.auth.token.email == 'cherukuridakshithsai@gmail.com';
    }

    // Returns true if the authenticated user has the 'owner' role.
    // Checks owner email first (no Firestore read needed), then custom claims,
    // then falls back to the staff profile document.
    function isOwner() {
      return isOwnerByEmail() ||
             (isAuthenticated() &&
              (request.auth.token.role == 'owner' ||
               (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) &&
                callerProfile().role == 'owner')));
    }

    // Returns true if the authenticated user is an active staff member or owner.
    // Owners always pass this check. Staff members must have status 'active'.
    function isActiveStaff() {
      return isOwner() ||
             (isAuthenticated() &&
              exists(/databases/$(database)/documents/staff/$(request.auth.uid)) &&
              (request.auth.token.status == 'active' || callerProfile().status == 'active') &&
              (request.auth.token.role == 'staff' || request.auth.token.role == 'owner' ||
               callerProfile().role == 'staff' || callerProfile().role == 'owner'));
    }

    // -------------------------------------------------------------------------
    // `menu` collection
    // Purpose: Menu items visible on the POS.
    // -------------------------------------------------------------------------
    match /menu/{itemId} {
      // Any active authenticated user can read the menu.
      allow read: if isActiveStaff();

      // Only the owner can write or modify menu items, and price must be positive.
      allow create, update: if isOwner() && request.resource.data.price > 0;
      allow delete: if isOwner();
    }

    // -------------------------------------------------------------------------
    // `orders` collection
    // Purpose: All orders placed by staff.
    // -------------------------------------------------------------------------
    match /orders/{orderId} {
      // Any active staff/owner can read orders.
      allow read: if isActiveStaff();

      // Active staff can create new orders.
      allow create: if isActiveStaff() && request.resource.data.total >= 0;

      // Only the owner can update orders.
      // Enforce validation: a cancelled order cannot be completed again.
      allow update: if isOwner() &&
                    (resource.data.orderStatus != 'cancelled' || request.resource.data.orderStatus == 'cancelled');

      // Orders should never be deleted.
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // `staff` collection
    // Purpose: Staff profiles and account settings.
    // -------------------------------------------------------------------------
    match /staff/{staffId} {
      // Any active staff member can read profiles.
      allow read: if isActiveStaff();

      // Only the owner can create new staff profiles.
      allow create: if isOwner();

      // Owner can update any field. A staff member can only update their own
      // name and contact.
      allow update: if isOwner() ||
                    (isAuthenticated() &&
                     request.auth.uid == staffId &&
                     request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['name', 'emailOrPhone']));

      // Only the owner can delete staff accounts.
      allow delete: if isOwner();
    }

    // -------------------------------------------------------------------------
    // `tokens` collection
    // Purpose: Student/customer stored-value token accounts.
    // -------------------------------------------------------------------------
    match /tokens/{tokenId} {
      // Any active staff/owner can read token accounts.
      allow read: if isActiveStaff();

      // Active staff can issue cards, but balance cannot be negative.
      allow create: if isActiveStaff() && 
                    request.resource.data.tokens >= 0 &&
                    (!('balanceRupees' in request.resource.data) || request.resource.data.balanceRupees >= 0);

      // Owner can update any field. Staff can only update the tokens balance field,
      // and balance can never be negative.
      allow update: if isOwner() && request.resource.data.tokens >= 0 ||
                    (isActiveStaff() &&
                     (request.auth.token.role == 'staff' || callerProfile().role == 'staff') &&
                     request.resource.data.tokens >= 0 &&
                     (!('balanceRupees' in request.resource.data) || request.resource.data.balanceRupees >= 0) &&
                     request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['tokens', 'balanceRupees', 'updatedAt']));

      // Only owner can delete token accounts.
      allow delete: if isOwner();
    }

    // -------------------------------------------------------------------------
    // `token_transactions` collection
    // Purpose: Immutable ledger of all token recharges, deductions, and refunds.
    // -------------------------------------------------------------------------
    match /token_transactions/{txId} {
      allow read: if isActiveStaff();
      allow create: if isActiveStaff();
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // `settings` collection
    // Purpose: Configuration options for Hau-Hau POS.
    // -------------------------------------------------------------------------
    match /settings/{settingsId} {
      allow read: if isActiveStaff();
      allow create, update: if isOwner();
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // `audit_logs` collection
    // Purpose: Immutable ledger of operational modifications.
    // -------------------------------------------------------------------------
    match /audit_logs/{logId} {
      allow read: if isOwner();
      allow create: if isActiveStaff();
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // All other collections — deny by default
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
